{
  "postgres": {
    "dsn": "postgres://nova:nova@localhost:5432/nova?sslmode=disable"
  },
  "secrets": {
  },
  "auth": {
    "enabled": false,
    "jwt": {
      "enabled": true,
      "algorithm": "HS256"
    }
  },
  "firecracker": {
    "backend": "docker",
    "binary": "/opt/nova/bin/firecracker",
    "kernel": "/opt/nova/kernel/vmlinux",
    "rootfs_dir": "../assets/rootfs",
    "snapshot_dir": "/tmp/nova/snapshots",
    "socket_dir": "/tmp/nova/sockets",
    "vsock_dir": "/tmp/nova/vsock",
    "log_dir": "/tmp/nova/logs"
  },
  "docker": {
    "code_dir": "/tmp/nova/code",
    "image_prefix": "nova-runtime"
  },
  "applevz": {
    "kernel_path": "../assets/kernel/Image-alpine-arm64",
    "initrd_path": "../assets/kernel/initramfs-alpine-arm64-vsock",
    "rootfs_dir": "../assets/rootfs",
    "code_dir": "/tmp/nova/applevz-code",
    "socket_dir": "/tmp/nova/applevz-socks",
    "nova_vz_path": "../bin/nova-vz",
    "snapshot_dir": "/tmp/nova/applevz-snapshots",
    "default_mem_mb": 256,
    "default_cpus": 1
  },
  "pool": {
    "idle_ttl": 120000000000
  },
  "runtime_pool": {
    "enabled": false
  },
  "gateway": {
    "enabled": true
  },
  "libkrun": {
    "code_dir": "/tmp/nova/libkrun-code",
    "port_range_min": 40000,
    "port_range_max": 40100
  },
  "kubernetes": {
    "namespace": "nova-functions",
    "image_prefix": "nova-runtime"
  },
  "wasm": {
    "code_dir": "/tmp/nova/wasm-code"
  }
}
